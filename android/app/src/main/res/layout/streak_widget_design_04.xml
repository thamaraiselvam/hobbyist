                android:layout_marginTop="5dp"
                android:background="@drawable/widget_day_pending"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />
        </LinearLayout>
        <LinearLayout
